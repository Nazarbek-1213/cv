# Bu faylni .env nomi bilan nusxa oling va to'ldiring
DEBUG=False
SECRET_KEY=replace-with-a-long-random-string
ALLOWED_HOSTS=127.0.0.1,localhost,.onrender.com
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# --- Visit ping → Telegram bot (optional) ---
# Saytga kirgan har bir tashrif Telegram bot orqali xabar qiladi.
# Ikkala qiymat bo'sh bo'lsa, /api/visit/ jim qoladi (no-op).
#
# Token olish: Telegram'da @BotFather -> /newbot
# Chat ID olish: Telegram'da @userinfobot -> /start
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Admin superuser (auto-yaratiladi seed_cv chaqirilganda) ---
# ADMIN_PASSWORD bo'sh bo'lsa, foydalanuvchi yaratilmaydi.
# Render Free tarif uchun MAJBURIY — chunki har deploy'da DB tozalanadi.
ADMIN_USERNAME=admin
ADMIN_EMAIL=
ADMIN_PASSWORD=
